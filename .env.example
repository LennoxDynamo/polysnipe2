# PolySnipe Backend Environment Configuration
# Copy this file to .env and fill in your values

# JWT Secret for signing authentication tokens
# IMPORTANT: Must be at least 32 characters long for HS256
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# Google OAuth 2.0 Client ID
# Get this from Google Cloud Console: https://console.cloud.google.com/
# Project > Create OAuth 2.0 Client ID > Web application
# Add http://localhost:8000 for local dev, your Railway domain for production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: Google OAuth Audience (usually same as CLIENT_ID)
# Only needed if using more advanced Google OAuth flows
# GOOGLE_AUDIENCE=your-google-client-id.apps.googleusercontent.com

# Optional: Deployment environment marker (set to 'railway' when on Railway)
# RAILWAY_ENVIRONMENT_NAME=railway

# Optional: Debug logging
# DEBUG=false
